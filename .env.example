# Database URL for Prisma to connect to MySQL.
# Use ssl-mode=REQUIRED when connecting to managed MySQL providers such as Aiven.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl-mode=REQUIRED
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl-mode=REQUIRED"

# Optional backup target directory for npm run backup:db.
DB_BACKUP_DIR="backups"

# Optional local demo mode. Keep real demo credentials only in .env.
DEMO_MODE="false"
DEMO_ADMIN_USERNAME=""
DEMO_ADMIN_PASSWORD=""

# Non-demo admin login. In production, set these in Vercel Environment Variables.
ADMIN_ACCOUNT=""
ADMIN_PASSWORD=""

# Legacy optional database seed admin. ADMIN_ACCOUNT/ADMIN_PASSWORD are preferred.
SEED_ADMIN_USERNAME=""
SEED_ADMIN_PASSWORD=""

# Google OAuth. Register this callback URL in Google Cloud:
# http://localhost:3000/api/auth/callback/google
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Session signing secret. Use a long random value in real deployments.
AUTH_SECRET=""
