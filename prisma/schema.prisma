generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(cuid())
  name      String
  desc      String   @db.Text
  price     String
  image     String
  createdAt DateTime @default(now())
}

model User {
  id                String   @id @default(cuid())
  email             String?  @unique
  username          String?  @unique
  displayName       String
  role              String   @default("customer") // customer, seller, shipper, admin
  status            String   @default("active") // active, blocked
  provider          String   @default("credentials") // credentials, google, facebook, instagram
  providerAccountId String
  passwordHash      String?
  passwordSalt      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  merchantProfile   MerchantProfile?

  @@unique([provider, providerAccountId])
}

model MerchantProfile {
  id          String   @id @default(cuid())
  ownerId     String?  @unique
  owner       User?    @relation(fields: [ownerId], references: [id])
  ownerRole   String?  @default("seller")
  shopName    String
  address     String
  mapLocation String?
  openTime    String
  closeTime   String
  phone       String
  image       String
  status      String   @default("pending_review") // active, paused, pending_review, blocked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id          String    @id @default(cuid())
  customer    Json      // Store customer info (name, phone, address, etc.)
  items       Json      // Store array of items {id, name, price, quantity, etc.}
  totalItems  Int
  totalPrice  Int
  status      String    @default("pending") // pending, ready_for_pickup, picked_up, delivering, completed
  shipperId   String?
  shipperName String?
  acceptedAt  DateTime?
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
}

model Proposal {
  id        String   @id @default(cuid())
  name      String
  desc      String   @db.Text
  price     String
  image     String
  status    String   @default("pending") // pending, accepted, rejected
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
