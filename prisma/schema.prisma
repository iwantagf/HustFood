generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String        @id @default(cuid())
  ownerId     String?
  owner       User?         @relation(fields: [ownerId], references: [id])
  categoryId  String?
  category    MenuCategory? @relation(fields: [categoryId], references: [id])
  name        String
  desc        String        @db.Text
  price       String
  image       String
  options     Json?
  isAvailable Boolean       @default(true)
  isHidden    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model MenuCategory {
  id        String    @id @default(cuid())
  ownerId   String?
  owner     User?     @relation(fields: [ownerId], references: [id])
  name      String
  createdAt DateTime  @default(now())
  products  Product[]
}

model User {
  id                String           @id @default(cuid())
  email             String?          @unique
  username          String?          @unique
  displayName       String
  role              String           @default("customer") // customer, seller, shipper, admin
  status            String           @default("active") // active, blocked
  provider          String           @default("credentials") // credentials, google, facebook, instagram
  providerAccountId String
  passwordHash      String?
  passwordSalt      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  merchantProfile   MerchantProfile?
  products          Product[]
  proposals         Proposal[]
  menuCategories    MenuCategory[]
  savedCart         SavedCart?

  @@unique([provider, providerAccountId])
}

model SavedCart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MerchantProfile {
  id          String   @id @default(cuid())
  ownerId     String?  @unique
  owner       User?    @relation(fields: [ownerId], references: [id])
  ownerRole   String?  @default("seller")
  shopName    String
  address     String
  mapLocation String?
  openTime    String
  closeTime   String
  phone       String
  image       String
  rating      Float    @default(4.5)
  reviewCount Int      @default(0)
  status      String   @default("pending_review") // active, paused, pending_review, blocked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                   String    @id @default(cuid())
  customerId           String?
  merchantId           String?
  merchantName         String?
  pickupAddress        String?
  pickupLocation       String?
  customer             Json // Store customer info (name, phone, address, etc.)
  items                Json // Store array of items {id, name, price, quantity, etc.}
  totalItems           Int
  totalPrice           Int
  deliveryFee          Int       @default(0)
  discount             Int       @default(0)
  finalTotal           Int       @default(0)
  paymentMethod        String    @default("cod") // cod, momo, card
  paymentStatus        String    @default("pending") // pending, paid, failed, retry_required
  paymentProvider      String?
  paymentTransactionId String?
  paymentChecksum      String?
  paymentFailureReason String?
  status               String    @default("pending") // pending, payment_retry, accepted, preparing, ready_for_pickup, picked_up, delivering, completed, rejected
  rejectionReason      String?   @db.Text
  shipperId            String?
  shipperName          String?
  sellerAcceptedAt     DateTime?
  readyForPickupAt     DateTime?
  rejectedAt           DateTime?
  acceptedAt           DateTime?
  pickedUpAt           DateTime?
  deliveredAt          DateTime?
  codAmount            Int       @default(0)
  codCollectedAt       DateTime?
  shipperIssue         String?   @db.Text
  shipperIssueAt       DateTime?
  shipperLatitude      Float?
  shipperLongitude     Float?
  shipperLocationAt    DateTime?
  createdAt            DateTime  @default(now())
}

model Voucher {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String
  discountType  String // fixed, percent
  discountValue Int
  minSubtotal   Int       @default(0)
  expiresAt     DateTime?
  usageLimit    Int?
  usedCount     Int       @default(0)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

model Proposal {
  id        String   @id @default(cuid())
  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id])
  name      String
  desc      String   @db.Text
  price     String
  image     String
  status    String   @default("pending") // pending, accepted, rejected
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  ownerId   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
